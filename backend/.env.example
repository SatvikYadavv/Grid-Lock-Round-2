APP_NAME=TraffiSense AI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/traffisense_ai
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_AUTO_CREATE_TABLES=false

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

UPLOAD_DIR=storage/uploads
MAX_UPLOAD_MB=20
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

AI_PROCESSING_ENABLED=false
YOLO_MODEL_PATH=
OCR_LANGUAGES=en

LOG_LEVEL=INFO

